# ── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA-replace-me

# Your numeric Telegram user ID (get from @userinfobot)
# The bot will ignore messages from anyone else.
ALLOWED_USER_ID=123456789

# Buffer access token: publish.buffer.com/settings/api → API (Beta) → Create Token
BUFFER_ACCESS_TOKEN=1/replace-me

# ── Recommended ───────────────────────────────────────────────────────────────

# imgbb API key (free): https://api.imgbb.com/
# Primary image host. Buffer requires public image URLs — without imgbb the bot
# falls back to catbox.moe and 0x0.st, which are flakier.
IMGBB_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Binance Square OpenAPI key — enables crypto-content publishing to Binance Square.
# Get from: Binance Square Creator Center.
BINANCE_SQUARE_API_KEY=

# Scheduling window in hours. Each forwarded post gets a random dueAt in this range.
# Defaults: 1h min, 240h (10 days) max.
SCHEDULE_MIN_HOURS=1
SCHEDULE_MAX_HOURS=240

# SQLite path. Default: /app/data/bot.db (Docker / Railway volume).
# For local dev: ./bot.db
DB_PATH=/app/data/bot.db
